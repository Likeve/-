generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ActivationCode {
  id           String    @id @default(cuid())
  code         String    @unique // e.g. VIP-XXXX-XXXX
  durationDays Int       // 1, 3, 15, or 30
  isUsed       Boolean   @default(false)
  usedAt       DateTime?
  createdAt    DateTime  @default(now())
}
